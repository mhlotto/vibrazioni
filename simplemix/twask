#!/usr/bin/env python3

import json
import os
import sys
import urllib.error
import urllib.request
from typing import Optional


DEFAULT_BASE_URL = "http://192.168.1.100:8080/v1"
DEFAULT_MODEL = "Qwen/Qwen3-4B-GGUF"


def usage() -> None:
    prog = os.path.basename(sys.argv[0])
    print(
        f"Usage: {prog} \"your first question\"  or  echo \"your first question\" | {prog}",
        file=sys.stderr,
    )
    print(
        f"After the first reply, {prog} asks for one follow-up on stdin.",
        file=sys.stderr,
    )


def build_endpoint(base_url: str) -> str:
    return base_url.rstrip("/") + "/chat/completions"


def read_first_prompt() -> str:
    if len(sys.argv) > 1:
        return " ".join(sys.argv[1:]).strip()
    if not sys.stdin.isatty():
        return sys.stdin.read().strip()
    return ""


def request_chat(messages, base_url: str, model: str, api_key: Optional[str]) -> str:
    payload = {
        "model": model,
        "messages": messages,
        "stream": False,
    }

    headers = {
        "Content-Type": "application/json",
    }
    if api_key:
        headers["Authorization"] = f"Bearer {api_key}"

    request = urllib.request.Request(
        build_endpoint(base_url),
        data=json.dumps(payload).encode("utf-8"),
        headers=headers,
        method="POST",
    )

    try:
        with urllib.request.urlopen(request) as response:
            body = json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")
        print(f"HTTP error: {exc.code} {exc.reason}", file=sys.stderr)
        if detail:
            print(detail, file=sys.stderr)
        raise SystemExit(1)
    except urllib.error.URLError as exc:
        print(f"Request failed: {exc}", file=sys.stderr)
        raise SystemExit(1)

    try:
        content = body["choices"][0]["message"]["content"]
    except (KeyError, IndexError, TypeError):
        print("Unexpected response:", file=sys.stderr)
        print(json.dumps(body, indent=2), file=sys.stderr)
        raise SystemExit(1)

    if isinstance(content, list):
        return "".join(
            part.get("text", "") for part in content if isinstance(part, dict)
        ).strip()
    return str(content).strip()


def read_follow_up() -> str:
    try:
        return input("follow-up> ").strip()
    except EOFError:
        return ""


def main() -> int:
    first_prompt = read_first_prompt()
    if not first_prompt:
        usage()
        return 2

    base_url = os.environ.get("OPENAI_BASE_URL", DEFAULT_BASE_URL)
    model = os.environ.get("OPENAI_MODEL", DEFAULT_MODEL)
    api_key = os.environ.get("OPENAI_API_KEY")

    messages = [
        {"role": "user", "content": first_prompt},
    ]

    first_reply = request_chat(messages, base_url, model, api_key)
    print(first_reply)

    follow_up = read_follow_up()
    if not follow_up:
        return 0

    messages.extend(
        [
            {"role": "assistant", "content": first_reply},
            {"role": "user", "content": follow_up},
        ]
    )

    second_reply = request_chat(messages, base_url, model, api_key)
    print(second_reply)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
